# Application
APP_NAME=BidPilot
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
# Comma-separated origins allowed by CORS (no wildcard; credentials disabled)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL
POSTGRES_USER=bidpilot
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=bidpilot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://bidpilot:change_me_postgres@localhost:5432/bidpilot

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio
MINIO_BUCKET=bidpilot-documents
MINIO_SECURE=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Upload limits (bytes); enforced while streaming, not from Content-Length
MAX_UPLOAD_SIZE_BYTES=52428800

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME=bidpilot_chunks_v1

# OpenSearch (BM25; dev compose runs single-node with security disabled)
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX_NAME=bidpilot_chunks_v1

# Retrieval models (sentence-transformers; CPU works, CUDA used when available)
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
RERANKER_MODEL_NAME=BAAI/bge-reranker-base

# Retrieval pipeline parameters
RETRIEVAL_DENSE_TOP_K=30
RETRIEVAL_BM25_TOP_K=30
RETRIEVAL_FUSION_TOP_K=20
RETRIEVAL_RERANK_TOP_K=8
RETRIEVAL_RRF_K=60

# LLM / OpenAI-compatible API (legacy / data_pipeline labeling)
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini
DATASET_MODEL_NAME=gpt-4o-mini

# Grounded RAG (vLLM Qwen3-8B). Disabled by default so CPU/CI envs still boot.
# Single config source for scripts/serve_qwen3_vllm.sh and docker-compose.llm*.yml:
LLM_ENABLED=false
LLM_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=local
LLM_MODEL=bidpilot-qwen3-8b
LLM_MODEL_SOURCE=Qwen/Qwen3-8B
# Optional local weights directory (must contain config.json). Leave empty to use Hub id.
# Example: LLM_MODEL_PATH=/data/models/Qwen3-8B
LLM_MODEL_PATH=
LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1
RAG_CONTEXT_TOP_K=8
RAG_MAX_CONTEXT_TOKENS=10000
# Conservative floor for bge-reranker-base logits; raise to drop weak chunks.
RAG_MIN_RERANK_SCORE=-5.0


# LLaMAFactory (external installation path)
LLAMAFACTORY_HOME=/path/to/LLaMA-Factory

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Demo import
DEMO_DATA_PATH=./demo_data
DEFAULT_ORGANIZATION_NAME=BidPilot Demo Org
