# Application
APP_NAME=BidPilot
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# PostgreSQL
POSTGRES_USER=bidpilot
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=bidpilot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://bidpilot:change_me_postgres@localhost:5432/bidpilot

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio
MINIO_BUCKET=bidpilot-documents
MINIO_SECURE=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# LLM / OpenAI-compatible API
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini
DATASET_MODEL_NAME=gpt-4o-mini


# LLaMAFactory (external installation path)
LLAMAFACTORY_HOME=/path/to/LLaMA-Factory

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Demo import
DEMO_DATA_PATH=./demo_data
DEFAULT_ORGANIZATION_NAME=BidPilot Demo Org
